# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# …but .env.example is a placeholder template — safe and required to commit.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# design reference (not part of the codebase)
/Sveta Cecilija/

# claude local files
/.claude/

# runtime logs (dev artifacts)
/docs/logs.txt
/docs/runtime-logs.txt

# Payload CMS - auto-generated build artifacts
