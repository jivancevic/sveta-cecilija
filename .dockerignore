# Exclude the bulky photo originals, but keep the two asset trees the ticket-PDF
# renderer reads at runtime (render-tickets-pdf.tsx: email fonts + PNG logo).
# Exclude by contents (assets/*) not the dir itself, so the !re-includes apply.
assets/*
!assets/fonts
assets/fonts/*
!assets/fonts/email
# Brand fonts resolved by next/font/local at build time (prototype/fonts.ts).
!assets/fonts/brand
!assets/images
assets/images/*
!assets/images/cecilija-logo.png
Sveta Cecilija/
docs/
*.ods
.env*
.claude/
npm-debug.log*
