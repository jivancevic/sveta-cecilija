# Template for environment variables. Safe to commit — values here are
# placeholders only, never real secrets.
#
# Local dev: copy to .env.local and fill in. The local Postgres database
# is named `sveta_cecilija_dev` (production uses `sveta_cecilija` on the
# Hetzner host) — keep them distinct so a misconfigured DATABASE_URL
# cannot accidentally read or write the wrong database.
#
# Production: set these in Coolify env settings, NOT in any file in the
# repo. .env.local and .env.production are gitignored.

# Postgres connection. Local default below; prod points at Hetzner.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sveta_cecilija_dev

# Random 32+ byte string. Generate locally with: openssl rand -hex 32
PAYLOAD_SECRET=replace-me

# Where the app is reached. Local: http://localhost:3000. Prod: https://moreska.eu
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Deployment environment marker. Leave UNSET in local dev and production.
# Set to `staging` ONLY on the dev.moreska.eu Coolify app — it switches on the
# blanket robots.txt disallow + `X-Robots-Tag: noindex` header so staging is
# never indexed. (Email isolation via DEV_EMAIL_OVERRIDE below is separate.)
# NEXT_PUBLIC_ENV=staging

# Staging-only email kill switch. Leave UNSET in local dev and production.
# When set (on dev.moreska.eu), the Brevo transport rewrites every outgoing
# `to:` to this address and tags the subject `[DEV → original@addr]`, so no
# staging email can ever reach a real buyer (Brevo has one shared key). The
# runtime wiring lands in issue #152; this documents the key it reads.
# DEV_EMAIL_OVERRIDE=josip.ivancevic00@gmail.com

# Stripe — use sk_test_ / pk_test_ locally, sk_live_ / pk_live_ in prod.
# Webhook secret comes from `stripe listen` locally or the Stripe dashboard
# endpoint in prod. Never share live keys outside Coolify.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Payment-method configuration to apply at checkout (Card + Apple Pay + Google Pay).
# Pin this so checkout doesn't fall back to a legacy WooCommerce account-default config.
# Mode-specific: use the live pmc_ id in Coolify, the sandbox pmc_ id locally.
# If unset, Stripe uses the account default. Find ids under Settings → Payment methods.
STRIPE_PMC_ID=pmc_replace_me

# Brevo transactional email. One key per environment is fine; treat as a
# production credential even on test keys (Brevo has no separate test mode).
BREVO_API_KEY=replace_me

# Optional — Google Analytics measurement ID. Leave blank to disable GA.
# NEXT_PUBLIC_GA_ID=

# Optional — Meta (Facebook) Pixel ID. Leave blank to disable Meta Pixel.
# Loads only after the visitor accepts the cookie banner.
NEXT_PUBLIC_META_PIXEL_ID=

# Signing secret for buyer-side ticket download links (/api/orders/[id]/tickets.pdf?t=...).
# Separate from PAYLOAD_SECRET so it can be rotated independently — rotating
# this invalidates all in-flight ticket download links but does not log out
# admins. Generate locally with: openssl rand -hex 32
TICKET_LINK_SECRET=replace_me

# Shared secret for cron-triggered endpoints (e.g. /api/cron/send-review-emails).
# External scheduler hits the route with `Authorization: Bearer $CRON_SECRET`.
# Generate locally with: openssl rand -hex 32
CRON_SECRET=replace_me

# Optional — review-request email destinations.
# TripAdvisor: listing d1898279 (see issue #35).
# Google: filled in once the Google Business Profile is live (issue #36);
# defaults to a Google Maps search fallback so users aren't dead-ended.
# TRIPADVISOR_REVIEW_URL=
# GOOGLE_REVIEW_URL=
