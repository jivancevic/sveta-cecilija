# Template for environment variables. Safe to commit — values here are
# placeholders only, never real secrets.
#
# Local dev: copy to .env.local and fill in. The local Postgres database
# is named `sveta_cecilija_dev` (production uses `sveta_cecilija` on the
# Hetzner host) — keep them distinct so a misconfigured DATABASE_URL
# cannot accidentally read or write the wrong database.
#
# Production: set these in Coolify env settings, NOT in any file in the
# repo. .env.local and .env.production are gitignored.

# Postgres connection. Local default below; prod points at Hetzner.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sveta_cecilija_dev

# Random 32+ byte string. Generate locally with: openssl rand -hex 32
PAYLOAD_SECRET=replace-me

# Where the app is reached. Local: http://localhost:3000. Prod: https://moreska.eu
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe — use sk_test_ / pk_test_ locally, sk_live_ / pk_live_ in prod.
# Webhook secret comes from `stripe listen` locally or the Stripe dashboard
# endpoint in prod. Never share live keys outside Coolify.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Brevo transactional email. One key per environment is fine; treat as a
# production credential even on test keys (Brevo has no separate test mode).
BREVO_API_KEY=replace_me

# Optional — Google Analytics measurement ID. Leave blank to disable GA.
# NEXT_PUBLIC_GA_ID=
